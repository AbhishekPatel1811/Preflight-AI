{
  "name": "preflight-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "test:e2e": "playwright test --grep-invert @live",
    "test:e2e:ui": "playwright test --ui --grep-invert @live",
    "test:e2e:live": "playwright test e2e/live-agent.spec.ts",
    "test:all": "pnpm test && pnpm test:e2e"
  },
  "dependencies": {
    "@openai/agents": "latest",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "latest",
    "motion": "^12.40.0",
    "next": "latest",
    "openai": "latest",
    "react": "latest",
    "react-dom": "latest",
    "server-only": "latest",
    "tailwind-merge": "^3.6.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "eslint": "^9.39.1",
    "eslint-config-next": "latest",
    "postcss": "latest",
    "tailwindcss": "^3.4.17",
    "tsx": "latest",
    "typescript": "latest"
  }
}
